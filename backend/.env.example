# Server
PORT=3000
NODE_ENV=development

# PostgreSQL - pick ONE of the two configurations below.

# (A) Single connection string (preferred for Supabase / Neon / Render / RDS).
# When set, this takes precedence and SSL is enabled automatically.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# (B) Separate vars (used as fallback when DATABASE_URL is not set).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=car_parts
DB_CONNECTION_LIMIT=10
